# --- AI brains ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
OLLAMA_HOST=http://localhost:11434

CLAUDE_MODEL=claude-opus-4-8
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_MODEL=llama3

# --- Google Programmable Search (live news) ---
# Create at https://programmablesearchengine.google.com (search whole web)
GOOGLE_SEARCH_API_KEY=...
GOOGLE_SEARCH_CX=...

# --- Voice ---
TTS_VOICE=en-US-GuyNeural
WHISPER_MODEL_SIZE=base

# --- Zerodha / TradingView execution ---
KITE_API_KEY=...
KITE_ACCESS_TOKEN=...
TRADINGVIEW_WEBHOOK_SECRET=choose-a-long-random-string

# Safety rails — DRY_RUN=true logs orders without sending them to Zerodha.
# Set to false ONLY after you have verified the whole pipeline.
DRY_RUN=true
MAX_ORDER_QUANTITY=50
MAX_ORDERS_PER_DAY=20
# Comma-separated whitelist; empty = allow all symbols
ALLOWED_SYMBOLS=
